{
  "id": "air-quality",
  "name": "Air Quality",
  "version": "1.1.2",
  "minNoctaliaVersion": "3.6.0",
  "author": "adriamartin91",
  "license": "MIT",
  "repository": "https://github.com/noctalia-dev/noctalia-plugins",
  "description": "Displays real-time air quality data with EPA color coding. Supports Open-Meteo and AQICN data sources. Shows AQI index and pollutant breakdown.",
  "tags": ["Bar", "Desktop", "Panel", "System", "Utility"],
  "entryPoints": {
    "main": "Main.qml",
    "barWidget": "BarWidget.qml",
    "panel": "Panel.qml",
    "settings": "Settings.qml",
    "desktopWidget": "DesktopWidget.qml"
  },
  "dependencies": {
    "plugins": []
  },
  "metadata": {
    "defaultSettings": {
      "aqiScale": "us",
      "dataSource": "open-meteo",
      "aqicnToken": "",
      "useNoctaliaLocation": true,
      "customLatitude": "",
      "customLongitude": "",
      "refreshInterval": 30,
      "boldText": true
    }
  }
}
